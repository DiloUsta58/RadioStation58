    <style>
      body {
        font-family: 'Inter', sans-serif;
        background-color: #000;
        color: #ffffff;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        overflow-y: auto;
      }
      html {
        background-color: #000;
      }
      p a{
        display: inline-block;
        margin:5px 0
      }
      /* Custom Scrollbar for inner content */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.4);
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      html.app-view,
      html.app-view *,
      body.app-view,
      body.app-view * {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
      html.app-view *::-webkit-scrollbar,
      body.app-view *::-webkit-scrollbar {
        display: none;
      }
      @media (max-width: 839px) {
        body,
        body * {
          -ms-overflow-style: none;
          scrollbar-width: none;
        }
        body *::-webkit-scrollbar {
          display: none;
        }
      }
      .swiper-pagination.swiper-pagination-bullets {
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%) !important;
        display: flex;
        justify-content: center;
        gap: 8px;
        width: auto;
        text-align: center !important;
      }
      .overlay-center-50 {
        position: absolute;
        left: 50%;
        top: 50%;
        display: flex;
        height: 50px;
        width: 50px;
        transform: translate(-50%, -50%);
        align-items: center;
        justify-content: center;
        z-index: 10;
      }
      .overlay-circle-dark {
        display: flex;
        height: 50px;
        width: 50px;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background: rgba(0, 0, 0, 0.7);
      }
      .marquee {
        position: relative;
        overflow: hidden;
        white-space: nowrap;
      }
      .marquee__text {
        display: inline-block;
        padding-right: 16px;
      }
      .marquee__track {
        display: inline-flex;
        width: -moz-max-content;
        width: max-content;
        will-change: transform;
        animation: marquee-loop 14s linear infinite;
      }
      .marquee__item {
        flex: none;
        display: inline-block;
        padding-right: 16px;
      }
      @keyframes marquee-loop {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .marquee__track {
          animation: none;
        }
      }
      img,
      video {
        max-width: 100%;
        height: auto;
        display: inline-block !important;
      }
      .column_container {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        overflow: hidden;
        gap: 30px;
      }
      .column_container.middle_aligned { 
        align-items: center; align-content: flex-start;
      }
      .column_container:after{ 
        clear: both; content: ""; display: block; 
      }
      .column_container .column {
        box-sizing: border-box;
        flex: 1 1 0%;
        max-width: 100% !important;
        min-width: 0;
      }
      .column_container .column_3_1 {
        flex: 1 1 33.33%;
        width: 33.33%;
      }
      .column_container .column_3_2 {
        flex: 2 1 66.66%;
        width: 66.66%;
      }
      .column_container .column_4_1 {
        flex: 1 1 25%;
        width: 25%;
      }
      .column_container .column_4_2 {
        flex: 2 1 50%;
        width: 50%;
      }
      .column_container .column_4_3 {
        flex: 3 1 75%;
        width: 75%;
      }
      .column_container .column_5_1 {
        flex: 1 1 0%;
      }
      .column_container .column_5_2 {
        flex: 2 1 0%;
      }
      .column_container .column_5_3 {
        flex: 3 1 0%;
      }
      .column_container .column_5_4 {
        flex: 4 1 0%;
      }
      .column_container .column_6_1 {
        flex: 1 1 16.66%;
        width: 16.66%;
      }
      .column_container .column_6_2 {
        flex: 2 1 33.33%;
        width: 33.33%;
      }
      .column_container .column_6_3 {
        flex: 3 1 50%;
        width: 50%;
      }
      .column_container .column_6_4 {
        flex: 4 1 66.66%;
        width: 66.66%;
      }
      .column_container .column_6_5 {
        flex: 5 1 83.33%;
        width: 83.33%;
      }
      h1 {
        font-size: 24px !important;
        font-weight: 700 !important;
        margin: 20px 0;
        line-height: normal !important;
      }
      h2 {
        font-size: 20px !important;
